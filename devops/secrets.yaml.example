apiVersion: v1
kind: Secret
metadata:
  name: costify-secrets
  namespace: costify
type: Opaque
stringData:
  POSTGRES_USER: costify
  POSTGRES_PASSWORD: CHANGE_ME_STRONG_PASSWORD
  # Prisma defaults to cpus*2+1 connections, which on a 1-CPU pod is 3 — too
  # low for any real concurrency. The publish/import flows fan out many
  # parallel queries and hit pool timeouts at 3. Bump to 20 + 30s timeout.
  DATABASE_URL: postgresql://costify:CHANGE_ME_STRONG_PASSWORD@postgres:5432/costify?connection_limit=20&pool_timeout=30
  UMAMI_DATABASE_URL: postgresql://costify:CHANGE_ME_STRONG_PASSWORD@postgres:5432/umami
  SESSION_SECRET: CHANGE_ME_RANDOM_64_CHARS
  ANTHROPIC_API_KEY: sk-ant-CHANGE_ME
  # MinIO root credentials. For our scale we just use the root account
  # directly for both MinIO admin and S3-compatible API access. Bootstrap
  # only — for multi-tenant deployments, generate scoped IAM users via
  # the MinIO admin API.
  MINIO_ROOT_USER: costify-minio
  MINIO_ROOT_PASSWORD: CHANGE_ME_STRONG_PASSWORD
  S3_ACCESS_KEY_ID: costify-minio
  S3_SECRET_ACCESS_KEY: CHANGE_ME_STRONG_PASSWORD
  S3_ENDPOINT: http://minio:9000
  S3_BUCKET: costify-imports
---
apiVersion: v1
kind: Secret
metadata:
  name: registry-auth
  namespace: costify
type: Opaque
data:
  htpasswd: CHANGE_ME_BASE64_HTPASSWD
