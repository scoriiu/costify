apiVersion: v1
kind: Secret
metadata:
  name: costify-secrets
  namespace: costify
type: Opaque
stringData:
  POSTGRES_USER: costify
  POSTGRES_PASSWORD: CHANGE_ME_STRONG_PASSWORD
  # Prisma defaults to cpus*2+1 connections, which on a 1-CPU pod is 3 — too
  # low for any real concurrency. The publish/import flows fan out many
  # parallel queries and hit pool timeouts at 3. Bump to 20 + 30s timeout.
  DATABASE_URL: postgresql://costify:CHANGE_ME_STRONG_PASSWORD@postgres:5432/costify?connection_limit=20&pool_timeout=30
  UMAMI_DATABASE_URL: postgresql://costify:CHANGE_ME_STRONG_PASSWORD@postgres:5432/umami
  SESSION_SECRET: CHANGE_ME_RANDOM_64_CHARS
  ANTHROPIC_API_KEY: sk-ant-CHANGE_ME
---
apiVersion: v1
kind: Secret
metadata:
  name: registry-auth
  namespace: costify
type: Opaque
data:
  htpasswd: CHANGE_ME_BASE64_HTPASSWD
