apiVersion: v1
kind: Secret
metadata:
  name: costify-secrets
  namespace: costify
type: Opaque
stringData:
  POSTGRES_USER: costify
  POSTGRES_PASSWORD: CHANGE_ME_STRONG_PASSWORD
  DATABASE_URL: postgresql://costify:CHANGE_ME_STRONG_PASSWORD@postgres:5432/costify
  UMAMI_DATABASE_URL: postgresql://costify:CHANGE_ME_STRONG_PASSWORD@postgres:5432/umami
  SESSION_SECRET: CHANGE_ME_RANDOM_64_CHARS
  ANTHROPIC_API_KEY: sk-ant-CHANGE_ME
---
apiVersion: v1
kind: Secret
metadata:
  name: registry-auth
  namespace: costify
type: Opaque
data:
  htpasswd: CHANGE_ME_BASE64_HTPASSWD
