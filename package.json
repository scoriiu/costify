{
  "name": "costify",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "node prisma/seed.mjs",
    "postinstall": "prisma generate",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:watch": "vitest",
    "test:fixtures:bake": "tsx scripts/build-fixture-snapshot.ts",
    "test:client": "vitest run tests/unit/modules/balances/client-reconciliation",
    "typecheck": "tsc --noEmit",
    "golden": "tsx tests/golden/run.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1054.0",
    "@aws-sdk/lib-storage": "^3.1054.0",
    "@prisma/client": "^6.19.3",
    "@tanstack/react-virtual": "^3.13.24",
    "bcryptjs": "^3.0.3",
    "busboy": "^1.6.0",
    "clsx": "^2.1.1",
    "exceljs": "^4.4.0",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "pg": "^8.21.0",
    "pg-copy-streams": "^7.0.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "recharts": "^3.8.1",
    "sax": "^1.6.0",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "yauzl": "^3.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.96.0",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/busboy": "^1.5.4",
    "@types/node": "^25.8.0",
    "@types/pg": "^8.20.0",
    "@types/pg-copy-streams": "^1.2.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/sax": "^1.2.7",
    "@types/yauzl": "^2.10.3",
    "dotenv": "^17.4.2",
    "eslint": "^10.3.0",
    "eslint-config-next": "16.2.6",
    "openai": "^6.37.0",
    "prisma": "^6.19.3",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "prisma",
      "sharp",
      "unrs-resolver"
    ]
  }
}
