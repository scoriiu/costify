generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Identity role of a user.
/// - ACCOUNTANT: a person who manages a portfolio of client firms. Default.
/// - OWNER: a person who owns or runs one or more firms. Sees only `/firma`.
/// One user has exactly one identity role. Authorization beyond that is RBAC.
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  passwordHash  String
  emailVerified Boolean   @default(false)
  active        Boolean   @default(true)
  userRole      String    @default("ACCOUNTANT") // "ACCOUNTANT" | "OWNER"
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions         Session[]
  clients          Client[]
  clientAccesses   ClientAccess[]
  publishedPeriods PublishedPeriod[]

  @@index([userRole])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  ipAddress String?
  userAgent String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@index([expiresAt])
}

model Client {
  id               String   @id @default(cuid())
  userId           String
  name             String
  slug             String
  cui              String?
  caen             String?
  /// @deprecated Use TaxRegimePeriod timeline instead. Kept as fallback until all clients have at least one TaxRegimePeriod row.
  taxRegime        String   @default("profit_standard")
  active           Boolean  @default(true)
  /// PR-2c. When true, the firm tracks costs and revenues per business
  /// vertical (Outsourcing, Recruitment, Coworking for QHM21; project
  /// names for a construction firm; service lines for a SaaS). Most small
  /// firms have only one implicit vertical — leave this false. When
  /// flipped on, a default "Toata firma" Vertical is auto-created so
  /// every account immediately has somewhere to land.
  verticalsEnabled Boolean  @default(false)
  /// Monotonic counter bumped whenever data that affects computed outputs
  /// (balance, CPP, mapari, owner snapshot, KPIs) changes:
  ///   - journal upload / soft-delete (any JournalLine write)
  ///   - mapari overrides (AccountCategoryMapping, PartnerCategoryOverride)
  ///   - vertical config (Vertical, VerticalAllocation, CategoryVerticalAllocation, verticalsEnabled)
  /// This is the cache key suffix for unstable_cache wrapping of every heavy
  /// loader, so a cache hit guarantees the cached value matches the current
  /// data state — no manual revalidation needed. See modules/clients/data-version.ts.
  dataVersion      Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user                     User                         @relation(fields: [userId], references: [id], onDelete: Cascade)
  journalLines             JournalLine[]
  importEvents             ImportEvent[]
  journalPartners          JournalPartner[]
  clientAccounts           ClientAccount[]
  taxRegimePeriods         TaxRegimePeriod[]
  computedPeriods          ComputedPeriod[]
  accesses                 ClientAccess[]
  publishedPeriods         PublishedPeriod[]
  costCategories           CostCategory[]
  accountCategoryMaps      AccountCategoryMapping[]
  partnerCategoryOverrides PartnerCategoryOverride[]
  verticals                Vertical[]
  verticalAllocations      VerticalAllocation[]
  categoryVerticalAllocs   CategoryVerticalAllocation[]
  firmVerticalDefault      FirmVerticalDefault?
  partnerVerticalAllocs    PartnerVerticalAllocation[]

  @@unique([userId, slug])
  @@index([userId])
}

/// Grants an OWNER user read access to a Client's /firma dashboard.
/// One row = one (user, client, role) triple.
///
/// An OWNER may have many ClientAccess rows (multi-firm owners are common in RO).
/// ACCOUNTANTs do NOT get a ClientAccess row — they reach their clients via
/// Client.userId (they own the client record itself in the cabinet's portfolio).
model ClientAccess {
  id        String   @id @default(cuid())
  userId    String
  clientId  String
  role      String   @default("OWNER") // "OWNER" for now; future: "OPERATOR" etc.
  createdBy String? // user id of the ACCOUNTANT who granted access (audit context)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([userId, clientId])
  @@index([userId])
  @@index([clientId])
}

/// A snapshot of computed financials for one (client, year, month) period that
/// the accountant has explicitly marked as visible to the firm's OWNER(s).
///
/// Publishing semantics:
///   - The OWNER only sees periods that have a row here.
///   - The displayed values come from `snapshotData` (frozen at publish time),
///     NOT from a live recompute. This protects the patron from in-flight
///     accountant edits and lets us answer "what did Sorin see on April 18?".
///   - Re-publishing the same (clientId, year, month) overwrites `snapshotData`,
///     `publishedAt`, `noteForOwner` and bumps the audit trail.
///   - Unpublishing deletes the row; OWNER then sees the next-most-recent
///     published period, or the "nothing published yet" empty state.
///
/// `snapshotData` shape is versioned via `snapshotVersion` so we can migrate
/// the JSON forward as the OwnerSnapshot type evolves. See `modules/publishing`.
model PublishedPeriod {
  id              String    @id @default(cuid())
  clientId        String
  year            Int
  month           Int // 1..12
  publishedBy     String // accountant userId
  publishedAt     DateTime  @default(now())
  noteForOwner    String? // optional one-liner shown to the OWNER ("Salariile dec incluse")
  snapshotVersion Int       @default(1)
  snapshotData    Json // serialized OwnerSnapshot (summary, cashPosition, trends, etc.)
  snapshotHash    String // SHA-256 of canonical snapshot JSON. Used by audit + change detection.
  /// Non-null means: the underlying journal for this period changed after `publishedAt`,
  /// and the accountant should re-publish. Set by import/delete services, cleared by publish.
  /// Index supports "list stale periods for this client" in O(log n).
  staleSince      DateTime?

  client    Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  publisher User   @relation(fields: [publishedBy], references: [id])

  @@unique([clientId, year, month])
  @@index([clientId, year(sort: Desc), month(sort: Desc)])
  @@index([clientId, publishedAt(sort: Desc)])
  @@index([clientId, staleSince])
}

/// PR-2c. A business vertical (axa B) for one client.
///
/// Verticals are strictly per-firm: QHM21 has Outsourcing/Recruitment/
/// Coworking; a construction firm has Proiect-Bucuresti/Proiect-Cluj.
/// Two different clients can have a Vertical with the same `name` — they
/// are isolated by `clientId`. There is no global template.
///
/// Lifecycle:
///   - Verticals exist only when Client.verticalsEnabled = true. Disabling
///     the flag hides them everywhere but keeps the rows for safe re-enable.
///   - One vertical per client carries `isDefault = true` ("Toata firma" by
///     convention). It catches accounts with no explicit allocation so the
///     totals always reconcile. Default is auto-created on activation.
///   - Accountant freely renames, reorders and adds verticals. They cannot
///     delete the default — they can only rename it.
model Vertical {
  id        String   @id @default(cuid())
  clientId  String
  name      String
  position  Int      @default(0)
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client              Client                       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  allocations         VerticalAllocation[]
  categoryAllocations CategoryVerticalAllocation[]

  @@unique([clientId, name])
  @@index([clientId])
}

/// PR-2c. Maps a Romanian chart-of-accounts entry to one or more Verticals
/// with percentages, scoped to one client.
///
/// Two scopes supported (same convention as AccountCategoryMapping):
///   - "contBase":  applies to every analytic under the 3-digit base unless
///                  an analytic-scope row overrides it.
///   - "analytic":  applies to the full analytic cont and wins over base.
///
/// `splits` shape: `[{ "verticalId": "...", "percent": 60 }, ...]`.
/// Invariants enforced in the service layer (validation on every write):
///   - 1 to 5 entries,
///   - all percent values are integers 1..100,
///   - sum(percent) === 100,
///   - all verticalIds belong to the same client and exist.
///
/// Accounts WITHOUT a matching row roll up to the client's default Vertical
/// (the "Toata firma" one). This guarantees totals reconcile across breakdowns.
model VerticalAllocation {
  id        String   @id @default(cuid())
  clientId  String
  scope     String // "contBase" | "analytic"
  cont      String
  splits    Json // [{ verticalId, percent }]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  // Convenience FK so cascading deletes (vertical removed) can be detected by
  // the service layer. Not all splits link here — only the first one. This is
  // an indexing/audit helper, not a uniqueness constraint.
  primaryVerticalId String?
  primaryVertical   Vertical? @relation(fields: [primaryVerticalId], references: [id], onDelete: SetNull)

  @@unique([clientId, cont])
  @@index([clientId])
  @@index([primaryVerticalId])
}

/// Hierarchical patron-facing taxonomy for one client. The accountant edits
/// this tree in the "Categorii" tab; the OWNER consumes the result on /firma
/// under "Unde s-au dus banii" / "De unde au venit banii".
///
/// Each row is one node. Roots have `parentId = null`. Recursion through
/// `parent`/`children` allows arbitrary depth; the UI suggests 4 levels but
/// does not enforce a hard cap so the model survives Sorin-style 5-level
/// decompositions (Outsourcing > Echipa > Salarii > Bonus > Q4).
///
/// `kind` is fixed at the root and inherited by all descendants — a tree
/// is always pure "expense" or pure "revenue". Mixing is not meaningful for
/// the patron view.
///
/// `isOmfpDefault` marks nodes seeded by the auto-bootstrap from OMFP labels.
/// They can be renamed or deleted, but the UI shows a small badge so the
/// accountant knows what was the system's starting point.
model CostCategory {
  id            String   @id @default(cuid())
  clientId      String
  parentId      String?
  name          String
  kind          String // "expense" | "revenue"
  position      Int      @default(0)
  isOmfpDefault Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  client             Client                      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  parent             CostCategory?               @relation("CostCategoryTree", fields: [parentId], references: [id], onDelete: Cascade)
  children           CostCategory[]              @relation("CostCategoryTree")
  mappings           AccountCategoryMapping[]
  partnerOverrides   PartnerCategoryOverride[]
  verticalAllocation CategoryVerticalAllocation?

  @@unique([clientId, parentId, name])
  @@index([clientId])
  @@index([clientId, kind])
  @@index([parentId])
}

/// Optional vertical split for a CostCategory. Used by the partner-override
/// residue pathway: when a partner override redirects rulaj from a cont to a
/// category, the redirected slice follows THIS allocation if defined, or the
/// firm's default vertical otherwise.
///
/// Same `splits` shape and invariants as VerticalAllocation:
///   - 1..5 entries, sum(percent) === 100, all integers 1..100,
///   - all verticalIds belong to the same client and exist.
///
/// One row per category (unique constraint). Absence of a row means "use the
/// firm default vertical" — the absence is the explicit fallback, not an error.
model CategoryVerticalAllocation {
  id         String   @id @default(cuid())
  clientId   String
  categoryId String   @unique
  splits     Json // [{ verticalId, percent }]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  client   Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  category CostCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  primaryVerticalId String?
  primaryVertical   Vertical? @relation(fields: [primaryVerticalId], references: [id], onDelete: SetNull)

  @@index([clientId])
  @@index([primaryVerticalId])
}

/// The firm-wide default split across business lines (linii de business).
/// This is the TOP of the allocation cascade: any cont/partner that doesn't
/// have its own rule inherits this split ("Urmeaza linia de business").
///
/// One row per client (unique). Absence means "no firm split configured yet"
/// — the resolver then falls back to the default Vertical at 100% (legacy
/// behaviour, so nothing breaks for clients who never set a firm split).
///
/// Changing this row re-resolves every inheriting cont/partner LIVE — there
/// is no re-stamping of downstream rows. Only conts/partners with their own
/// VerticalAllocation / PartnerVerticalAllocation are pinned and unaffected.
///
/// Same `splits` shape + invariants as VerticalAllocation:
///   1..5 entries, integer percent 1..100, sum(percent) === 100, all
///   verticalIds belong to the same client.
model FirmVerticalDefault {
  id        String   @id @default(cuid())
  clientId  String   @unique
  splits    Json // [{ verticalId, percent }]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
}

/// Partner-level line-of-business split — the most specific level of the LOB
/// cascade (partener > cont > categorie > firma). When a partener on a cont
/// serves one activity (e.g. a supplier used only by Outsourcing), pin its
/// split here. Absent = the partener inherits the cont's resolved split.
/// Keyed like PartnerCategoryOverride: (clientId, contBase, normalized name).
model PartnerVerticalAllocation {
  id                    String   @id @default(cuid())
  clientId              String
  contBase              String
  partnerNameNormalized String
  partnerNameOriginal   String
  splits                Json // [{ verticalId, percent }]
  primaryVerticalId     String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, contBase, partnerNameNormalized])
  @@index([clientId])
  @@index([clientId, contBase])
}

/// Maps a Romanian chart-of-accounts entry to a CostCategory leaf, scoped to
/// one client. Two scopes are supported:
///   - "contBase":  the base 3-digit code (e.g. "628") — applies to every
///                  analytic under it unless overridden.
///   - "analytic":  the full analytic code (e.g. "628.01") — wins over the
///                  base mapping at resolve time.
///
/// Resolution at query time (see modules/categories/resolver.ts):
///   1. Look up `scope=analytic` row for the exact `cont`.
///   2. Look up `scope=contBase` for `getContBase(cont)`.
///   3. Walk shorter prefixes (e.g. "628" → "62" → "6") until a match.
///   4. Fall back to OMFP hardcoded labels from PR-2a.
///
/// Uniqueness on `(clientId, cont)` enforces "one cont = one category". To
/// move a cont, the row is updated, not duplicated.
model AccountCategoryMapping {
  id         String   @id @default(cuid())
  clientId   String
  scope      String // "contBase" | "analytic"
  cont       String
  categoryId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  client   Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  category CostCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([clientId, cont])
  @@index([clientId])
  @@index([categoryId])
}

/// Partner-level override of the cont's default category. When a journal line
/// hits a cont where a partner-override exists for the partner involved, the
/// override category wins (precedence "Nivel 1 — Regulă pe partener", see
/// docs/ro/cashflow-limbajul-mapari.md).
///
/// Grain: (clientId, contBase, partnerNameNormalized). One row per partner
/// per cont base — not per analytic — because the override expresses a
/// business semantic decision ("OMV always means combustibil on cont 6022"),
/// and analytic splits in Saga are usually project/location, not partner.
///
/// `partnerNameNormalized` is produced by src/lib/partner-normalize.ts and
/// is the matching key. `partnerNameOriginal` keeps one representative spelling
/// for display in the UI ("OMV PETROM SRL") — it's the spelling at the time
/// the override was created and is not updated on subsequent occurrences.
///
/// `source` distinguishes how the override was created so the UI can surface
/// state (Nivel "auto-sugerată" vs "confirmată", see §9 of the language doc):
///   - "manual"    — contabilul mapat explicit.
///   - "bulk"      — vine din "aplica la toti" — confirmedAt set imediat.
///   - "suggested" — sistemul a pre-completat din memorie sau matching;
///                  confirmedAt este null pana cand contabilul valideaza.
model PartnerCategoryOverride {
  id                    String    @id @default(cuid())
  clientId              String
  contBase              String
  partnerNameNormalized String
  partnerNameOriginal   String
  categoryId            String
  source                String // "manual" | "bulk" | "suggested"
  confirmedAt           DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  client   Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  category CostCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([clientId, contBase, partnerNameNormalized])
  @@index([clientId])
  @@index([clientId, contBase])
  @@index([categoryId])
}

/// Timeline of tax regime transitions for a client.
/// Each row = one transition starting at `startDate` (inclusive). The regime
/// is valid until the next transition's startDate (exclusive), or forever if
/// this is the most recent entry.
///
/// To find the regime for a period (year Y, month M):
///   pick the row where startDate <= LAST_DAY(Y,M), ordered by startDate desc, limit 1.
/// If no rows exist, fall back to Client.taxRegime (legacy).
model TaxRegimePeriod {
  id        String   @id @default(cuid())
  clientId  String
  startDate DateTime @db.Date
  taxRegime String // profit_standard | profit_micro_1 | profit_micro_3 | profit_specific | imca | deferred
  reason    String? // optional free-text note: "scadere venituri sub 500k EUR"
  createdBy String? // user id who created this transition (null for synthetic/migration)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, startDate])
  @@index([clientId, startDate])
}

// ImportEvent doubles as both an audit record AND the queue job record.
// Lifecycle of `status`:
//   queued      -> file in object storage, awaiting a worker
//   parsing     -> worker has claimed it, decoding the XLSX
//   storing     -> writing parsed rows into JournalLine (most expensive stage)
//   finalizing  -> partner mappings, account upserts, version bump
//   ready       -> visible in the journal, balance recomputable
//   failed      -> terminal, errorMessage populated
//
// `lockedAt` + `lockedBy` are the atomic-claim mechanism: an `UPDATE ...
// WHERE lockedAt IS NULL RETURNING *` lets two pods race for the same job
// safely. If a worker crashes mid-import (pod restart, OOM), another pod
// reclaims the row once `lockedAt < now() - 5 minutes`.
model ImportEvent {
  id           String    @id @default(cuid())
  clientId     String
  fileName     String
  fileHash     String
  sourceFormat String    @default("saga")
  entriesAdded Int       @default(0)
  dateStart    DateTime?
  dateEnd      DateTime?
  status       String    @default("queued")
  createdAt    DateTime  @default(now())

  // Queue / progress fields.
  progress         Int       @default(0)
  progressLabel    String?
  totalEntries     Int?
  processedEntries Int?
  errorMessage     String?
  fileKey          String?
  attempts         Int       @default(0)
  lockedAt         DateTime?
  lockedBy         String?

  client       Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  journalLines JournalLine[]

  @@index([clientId, createdAt(sort: Desc)])
  @@index([status, lockedAt])
}

model JournalLine {
  id            String @id @default(cuid())
  clientId      String
  importEventId String

  data  DateTime
  year  Int
  month Int
  ndp   String

  contD     String
  contDBase String
  contC     String
  contCBase String
  suma      Decimal @default(0) @db.Decimal(18, 2)

  explicatie String
  felD       String   @default("")
  categorie  String?
  cod        String?
  validat    String?
  tva        Decimal? @db.Decimal(18, 2)

  dedupHash String?
  deletedAt DateTime?

  client      Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  importEvent ImportEvent @relation(fields: [importEventId], references: [id], onDelete: Cascade)

  @@index([clientId, year, month])
  @@index([clientId, deletedAt])
  @@index([clientId, contDBase])
  @@index([clientId, contCBase])
  @@index([clientId, dedupHash])
  // Pagination on Registru Jurnal (ORDER BY data DESC, ndp DESC) and on the
  // accountant-audit timeline. Before this index, `prisma.findMany` over the
  // 200k-row JournalLine forced a Parallel Seq Scan + top-N heapsort (~200 ms
  // in Postgres alone). With this index Postgres walks the btree in sort
  // order and stops at LIMIT (0.5 ms top page, 23 ms at offset 50k).
  @@index([clientId, data(sort: Desc), ndp(sort: Desc)])
  @@index([importEventId])
}

/// Materialized balance + KPI + CPP + CPP-F20 + tax regime per (client, year, month).
///
/// Populated by the import worker (eager) and the live-read fallback (lazy).
/// A row is valid iff `dataVersion` equals the current `Client.dataVersion` at
/// read time — same key-as-version model we use for in-memory caches. Stale
/// rows are simply ignored on read; a fresh recompute overwrites them. We
/// never DELETE on bump because two parallel imports / corrections could
/// race a delete against another worker's write.
///
/// Storage shape: each computed period is ~50 KB JSON for Upperhouse-sized
/// clients (846 balance rows). At 1,000 clients × ~24 months that's about
/// 1.2 GB — cheap on Postgres.
///
/// Why JSONB columns and not relational rows: balance rows have ~20 columns
/// of computed numbers each, joined across tables that don't exist as
/// such (no "BalanceRow" table). JSONB lets us snapshot exactly the shape
/// the API route returns to the client. Reads are one keyed SELECT and
/// the route handler skips fetch + compute + KPI + CPP entirely.
model ComputedPeriod {
  id          String @id @default(cuid())
  clientId    String
  year        Int
  month       Int
  /// Snapshot of Client.dataVersion at the moment of computation. If
  /// Client.dataVersion advances past this, the row is stale and ignored.
  dataVersion Int
  /// Tax regime that was active for this period when the snapshot was
  /// taken. Stored separately so the read path can return it without
  /// touching the journal.
  taxRegime   String

  /// BalanceRowView[] — exactly what /api/balance returns under `rows`.
  rows   Json
  /// ComputedKpis | null
  kpis   Json
  /// CppData | null
  cpp    Json
  /// CppF20Data | null
  cppF20 Json

  computedAt DateTime @default(now())
  /// How the row was populated. "eager" = import worker. "lazy" = read-fallback.
  computedBy String   @default("lazy")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, year, month])
  @@index([clientId, dataVersion])
}

model JournalPartner {
  id              String  @id @default(cuid())
  clientId        String
  analyticAccount String
  contBase        String
  partnerName     String
  cod             String?

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, analyticAccount])
  @@index([clientId, contBase])
  @@index([clientId, partnerName])
}

model AuditEvent {
  id            String   @id @default(cuid())
  tenantId      String
  actorId       String
  actorType     String
  pipelineStage String
  action        String
  entityType    String
  entityId      String
  before        Json?
  after         Json?
  metadata      Json     @default("{}")
  checksum      String
  createdAt     DateTime @default(now())

  @@index([tenantId, entityType, entityId])
  @@index([tenantId, pipelineStage, createdAt])
  @@index([actorId, createdAt])
  @@index([tenantId, createdAt])
}

model AccountCatalog {
  code       String @id
  name       String
  type       String // "A" | "P" | "B"
  classDigit Int

  cppGroup String? // "VENITURI_EXPLOATARE" | "CHELTUIELI_EXPLOATARE" | "VENITURI_FINANCIARE" | "CHELTUIELI_FINANCIARE"
  cppLabel String?

  // D6 / D17 — F20 detailed mapping (OMFP 1802 Anexa 3, rd. 01–62)
  // Row number as string to preserve sub-rows like "05a", "05b", ... and leading zeros
  cppLine      String?
  cppLineLabel String?

  special String? // legacy: "pl_closing" | "profit_distribution" | "profit_tax" | "micro_tax" — kept for compat

  // D5 — explicit behavioral flags (replace `special`)
  isClosing            Boolean @default(false) // 121, 1211, 1212 — excluded from CPP
  isProfitTax          Boolean @default(false) // 691, 694, 697, 698 — separate CPP line
  isProfitDistribution Boolean @default(false) // 129
  isExtraBilantier     Boolean @default(false) // class 8/9 — visible in balanta, hidden from bilant/CPP/KPI
  isIfrsOnly           Boolean @default(false) // OMFP 2844 only — hidden for OMFP 1802 clients by default

  // D8 — cash KPI membership
  cashRole String? // "cash_direct" (5121, 5311, etc) | "cash_advance" (542) | "transit" (581, 5125) — transit is excluded from KPI

  // D8 — receivables/payables roles
  arRole String? // "ar_primary" (4111) | "ar_doubtful" (4118) | "ar_pending" (418) | "customer_advance" (419, subtract)
  apRole String? // "ap_primary" (401, 404) | "ap_pending" (408) | "supplier_advance" (409, subtract)

  // D9 — VAT family
  vatRole String? // "vat_collected" (4427) | "vat_deductible" (4426) | "vat_payable" (4423) | "vat_receivable" (4424) | "vat_pending" (4428)

  // Grouping families (future KPIs)
  payrollRole String? // "salary" | "social_contrib" | null

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([classDigit])
  @@index([cppGroup])
  @@index([cppLine])
  @@index([isProfitTax])
  @@index([isExtraBilantier])
}

model ClientAccount {
  id          String   @id @default(cuid())
  clientId    String
  code        String
  customName  String
  source      String // "saga_import" | "user_edit" | "saga_explicatie" | "auto_created"
  partnerCode String?
  needsReview Boolean  @default(false) // D14: contBase not in AccountCatalog
  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, code])
  @@index([clientId])
  @@index([clientId, source])
  @@index([clientId, needsReview])
}

model DocAnswer {
  id          String   @id @default(cuid())
  docSlug     String
  sectionId   String
  sectionText String
  content     String
  authorId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([docSlug, sectionId])
  @@index([docSlug])
}
