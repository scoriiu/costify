generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  passwordHash  String
  emailVerified Boolean   @default(false)
  active        Boolean   @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions Session[]
  clients  Client[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  ipAddress String?
  userAgent String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@index([expiresAt])
}

model Client {
  id        String   @id @default(cuid())
  userId    String
  name      String
  slug      String
  cui       String?
  caen      String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  journalLines    JournalLine[]
  importEvents    ImportEvent[]
  journalPartners JournalPartner[]
  clientAccounts  ClientAccount[]

  @@unique([userId, slug])
  @@index([userId])
}

model ImportEvent {
  id           String   @id @default(cuid())
  clientId     String
  fileName     String
  fileHash     String
  sourceFormat String   @default("saga")
  entriesAdded Int      @default(0)
  dateStart    DateTime?
  dateEnd      DateTime?
  status       String   @default("processing")
  createdAt    DateTime @default(now())

  client       Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  journalLines JournalLine[]

  @@index([clientId, createdAt(sort: Desc)])
}

model JournalLine {
  id            String    @id @default(cuid())
  clientId      String
  importEventId String

  data      DateTime
  year      Int
  month     Int
  ndp       String

  contD     String
  contDBase String
  contC     String
  contCBase String
  suma      Decimal  @default(0) @db.Decimal(18, 2)

  explicatie String
  felD       String   @default("")
  categorie  String?
  cod        String?
  validat    String?
  tva        Decimal? @db.Decimal(18, 2)

  dedupHash String?
  deletedAt DateTime?

  client      Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  importEvent ImportEvent @relation(fields: [importEventId], references: [id], onDelete: Cascade)

  @@index([clientId, year, month])
  @@index([clientId, deletedAt])
  @@index([clientId, contDBase])
  @@index([clientId, contCBase])
  @@index([clientId, dedupHash])
  @@index([importEventId])
}

model JournalPartner {
  id              String @id @default(cuid())
  clientId        String
  analyticAccount String
  contBase        String
  partnerName     String
  cod             String?

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, analyticAccount])
  @@index([clientId, contBase])
  @@index([clientId, partnerName])
}

model AuditEvent {
  id            String   @id @default(cuid())
  tenantId      String
  actorId       String
  actorType     String
  pipelineStage String
  action        String
  entityType    String
  entityId      String
  before        Json?
  after         Json?
  metadata      Json     @default("{}")
  checksum      String
  createdAt     DateTime @default(now())

  @@index([tenantId, entityType, entityId])
  @@index([tenantId, pipelineStage, createdAt])
  @@index([actorId, createdAt])
  @@index([tenantId, createdAt])
}

model AccountCatalog {
  code       String   @id
  name       String
  type       String
  classDigit Int
  cppGroup   String?
  cppLabel   String?
  special    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([classDigit])
  @@index([cppGroup])
}

model ClientAccount {
  id          String   @id @default(cuid())
  clientId    String
  code        String
  customName  String
  source      String
  partnerCode String?
  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, code])
  @@index([clientId])
  @@index([clientId, source])
}
