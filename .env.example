DATABASE_URL="postgresql://postgres:postgres@localhost:5432/costify?schema=public"
SESSION_SECRET="change-me-to-a-random-64-char-string"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Comma-separated emails that can access /internal/* (design system, marketing,
# firma showcase). Public on purpose: client components read it to decide which
# nav items to show. Real security is the server-side route guards.
NEXT_PUBLIC_INTERNAL_USER_EMAILS=""

# Optional: slug of the client whose data powers /internal/firma showcase pages.
# Leave empty to disable the showcase. SHOWCASE_PERIOD is optional and defaults
# to the latest period with journal data.
SHOWCASE_CLIENT_SLUG=""
# SHOWCASE_PERIOD="2026-04"

# Costi CFO mode (ADR-0005 Stage 2): "on" = playbooks + Sonnet; anything else = legacy Costi
COSTI_CFO_MODE=off
# Costi CFO model override (default claude-sonnet-5). Lets prod swap models
# via env without a rebuild. Legacy (flag off) stays pinned to Haiku.
# COSTI_MODEL=claude-opus-4-8
